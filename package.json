{
  "name": "kawaz-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run clean && tsc",
    "build:watch": "tsc --watch",
    "build:advanced": "npm run clean:advanced && npm i && tsc",
    "start": "node --env-file .env dist/index.js",
    "start:dev": "npm run build && npm run start",
    "dev": "ts-node-dev --respawn --env-file .env src/index.ts",
    "clean": "rimraf dist",
    "clean:advanced": "rimraf dist && rimraf node_modules && rimraf package-lock.json"
  },
  "dependencies": {
    "ramda": "^0.32.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ido_kawaz/amqp-client": "^5.0.0",
    "@ido_kawaz/mongo-client": "^2.0.0",
    "@ido_kawaz/server-framework": "^2.2.0",
    "@ido_kawaz/storage-client": "^5.0.0",
    "@types/ramda": "^0.31.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "rimraf": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
